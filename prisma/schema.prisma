generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum UserRole {
  OWNER
  MEMBER
}

enum CurrencyCode {
  USD
  NGN
  EUR
  GBP
}

enum DebtCategory {
  CREDIT_CARD
  PERSONAL_LOAN
  MORTGAGE
  STUDENT_LOAN
  FAMILY_LOAN
  CAR_FINANCE
  BUY_NOW_PAY_LATER
  OTHER
}

enum DebtStatus {
  ACTIVE
  PAID
  ARCHIVED
}

enum IncomeFrequency {
  ONE_TIME
  WEEKLY
  BI_WEEKLY
  SEMI_MONTHLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum ReminderType {
  SALARY_PLANNING
}

enum FutureGoalType {
  HOUSE
  CAR
  VACATION
  EDUCATION
  WEDDING
  BUSINESS
  OTHER
}

enum GoalFundingStrategy {
  FULL_COST
  DOWN_PAYMENT
  CUSTOM_TARGET
}

enum SavingsEntryType {
  DEPOSIT
  WITHDRAWAL
}

model Category {
  id             String          @id @default(cuid())
  name           String          @db.VarChar(60)
  kind           CategoryKind
  color          String?         @db.VarChar(24)
  transactions   Transaction[]
  monthlyBudgets MonthlyBudget[]
  fixedExpenses  FixedExpense[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([name, kind])
  @@index([kind])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  date        DateTime        @db.Date
  amount      Decimal         @db.Decimal(12, 2)
  description String          @db.VarChar(120)
  categoryId  String?
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([userId, date])
}

model MonthlyBudget {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      DateTime @db.Date
  amount     Decimal  @db.Decimal(12, 2)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

model FixedExpense {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String       @db.VarChar(100)
  amount     Decimal      @db.Decimal(12, 2)
  currency   CurrencyCode @default(USD)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  dueDay     Int?
  startMonth DateTime     @db.Date
  active     Boolean      @default(true)
  notes      String?      @db.VarChar(240)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId, active])
  @@index([categoryId])
  @@index([startMonth])
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique @db.VarChar(254)
  name            String?         @db.VarChar(80)
  passwordHash    String
  role            UserRole        @default(MEMBER)
  sessions        Session[]
  invitationsSent Invitation[]    @relation("InvitationsSent")
  acceptedInvites Invitation[]    @relation("InvitationAcceptedBy")
  incomeSources   IncomeSource[]
  incomeEntries   IncomeEntry[]
  salaryCycles    SalaryCycle[]
  debts           Debt[]
  reminderEmails  ReminderEmail[]
  fixedExpenses   FixedExpense[]
  savingsGoals    SavingsGoal[]
  transactions    Transaction[]
  monthlyBudgets  MonthlyBudget[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Invitation {
  id           String    @id @default(cuid())
  email        String    @db.VarChar(254)
  tokenHash    String    @unique
  invitedById  String?
  invitedBy    User?     @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedById String?
  acceptedBy   User?     @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model IncomeSource {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String          @db.VarChar(80)
  isFixed        Boolean         @default(false)
  frequency      IncomeFrequency @default(MONTHLY)
  paymentDay     Int?
  active         Boolean         @default(true)
  versions       IncomeVersion[]
  entries        IncomeEntry[]
  reminderEmails ReminderEmail[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model IncomeVersion {
  id             String       @id @default(cuid())
  incomeSourceId String
  incomeSource   IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(12, 2)
  currency       CurrencyCode
  effectiveFrom  DateTime     @db.Date
  createdAt      DateTime     @default(now())

  @@unique([incomeSourceId, effectiveFrom])
  @@index([effectiveFrom])
}

model IncomeEntry {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSourceId String?
  incomeSource   IncomeSource?   @relation(fields: [incomeSourceId], references: [id], onDelete: SetNull)
  sourceName     String          @db.VarChar(80)
  amount         Decimal         @db.Decimal(12, 2)
  currency       CurrencyCode
  frequency      IncomeFrequency @default(ONE_TIME)
  receivedOn     DateTime        @db.Date
  note           String?         @db.VarChar(160)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, receivedOn])
  @@index([incomeSourceId])
}

model ReminderEmail {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSourceId String?
  incomeSource   IncomeSource? @relation(fields: [incomeSourceId], references: [id], onDelete: SetNull)
  type           ReminderType  @default(SALARY_PLANNING)
  dueOn          DateTime      @db.Date
  sentAt         DateTime      @default(now())
  emailSent      Boolean       @default(false)
  reason         String?       @db.VarChar(240)
  createdAt      DateTime      @default(now())

  @@unique([userId, incomeSourceId, type, dueOn])
  @@index([dueOn])
  @@index([userId])
}

model SalaryCycle {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  month            DateTime          @db.Date
  debtPaymentPlans DebtPaymentPlan[]
  debtPayments     DebtPayment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

model Debt {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String            @db.VarChar(100)
  category       DebtCategory      @default(OTHER)
  originalAmount Decimal           @db.Decimal(12, 2)
  currentBalance Decimal           @db.Decimal(12, 2)
  currency       CurrencyCode
  interestRate   Decimal?          @db.Decimal(5, 2)
  minimumPayment Decimal?          @db.Decimal(12, 2)
  dueDay         Int?
  notes          String?           @db.VarChar(500)
  status         DebtStatus        @default(ACTIVE)
  paidAt         DateTime?
  deletedAt      DateTime?
  paymentPlans   DebtPaymentPlan[]
  payments       DebtPayment[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, category])
  @@index([deletedAt])
}

model DebtPaymentPlan {
  id            String       @id @default(cuid())
  debtId        String
  debt          Debt         @relation(fields: [debtId], references: [id], onDelete: Cascade)
  salaryCycleId String
  salaryCycle   SalaryCycle  @relation(fields: [salaryCycleId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  currency      CurrencyCode
  note          String?      @db.VarChar(240)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([debtId, salaryCycleId])
  @@index([salaryCycleId])
}

model DebtPayment {
  id            String       @id @default(cuid())
  debtId        String
  debt          Debt         @relation(fields: [debtId], references: [id], onDelete: Cascade)
  salaryCycleId String
  salaryCycle   SalaryCycle  @relation(fields: [salaryCycleId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  currency      CurrencyCode
  paidOn        DateTime     @db.Date
  note          String?      @db.VarChar(240)
  createdAt     DateTime     @default(now())

  @@index([debtId])
  @@index([salaryCycleId])
  @@index([paidOn])
}

model SavingsGoal {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String                @db.VarChar(100)
  goalType      FutureGoalType        @default(OTHER)
  fundingStrategy GoalFundingStrategy @default(CUSTOM_TARGET)
  totalCost     Decimal?              @db.Decimal(12, 2)
  targetAmount  Decimal               @db.Decimal(12, 2)
  currency      CurrencyCode          @default(USD)
  deadline      DateTime              @db.Date
  notes         String?               @db.VarChar(240)
  contributions SavingsContribution[]
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([userId, archivedAt])
  @@index([deadline])
}

model SavingsContribution {
  id            String      @id @default(cuid())
  savingsGoalId String
  savingsGoal   SavingsGoal @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
  type          SavingsEntryType @default(DEPOSIT)
  amount        Decimal     @db.Decimal(12, 2)
  savedOn       DateTime    @db.Date
  note          String?     @db.VarChar(160)
  createdAt     DateTime    @default(now())

  @@index([savingsGoalId, savedOn])
  @@index([savedOn])
}
